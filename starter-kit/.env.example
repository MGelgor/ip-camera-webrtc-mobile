# Bu dosya sadece ornektir.
# Gercek kamera sifresi, kullanici bilgisi ve sunucu adresleri burada tutulmaz.
# Gercek degerler starter-kit/.env dosyasina yazilir.
# .env dosyasi .gitignore icinde oldugu icin repoya girmemelidir.

# Kamera bilgileri
CAMERA_NAME=ofis_kamera
CAMERA_IP=192.168.1.100
CAMERA_PORT=554
CAMERA_USER=CHANGE_ME
CAMERA_PASSWORD=CHANGE_ME

# RTSP yol parcalari
CAMERA_RTSP_MAIN_PATH=/live/main
CAMERA_RTSP_SUB_PATH=

# go2rtc / medya katmani
GO2RTC_API_PORT=1984
GO2RTC_WEBRTC_PORT=8555
GO2RTC_API_USERNAME=CHANGE_ME
GO2RTC_API_PASSWORD=CHANGE_ME

# Signaling server
SIGNALING_PORT=3000
SIGNALING_AUTH_TOKEN=CHANGE_ME
SIGNALING_TLS_CERT_PATH=
SIGNALING_TLS_KEY_PATH=

# WebRTC baglantilarinda kullanilacak yardimci sunucular
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:YOUR_PUBLIC_TURN_HOST:3478?transport=udp
TURN_USER=CHANGE_ME
TURN_PASSWORD=CHANGE_ME
TURN_REALM=multitek-turn
TURN_SERVER_NAME=multitek-coturn
TURN_PUBLIC_IP=203.0.113.10
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
