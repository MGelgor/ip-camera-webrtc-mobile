# Gateway on the camera LAN
GATEWAY_HOST=10.1.1.3
GO2RTC_API_USERNAME=replace-me
GO2RTC_API_PASSWORD=replace-me
GO2RTC_API_PORT=1984
GO2RTC_WEBRTC_PORT=8555

# ICE servers. Static TURN credentials are acceptable for the current test;
# production should issue short-lived credentials.
STUN_URL=stun:stun.cloudflare.com:3478
TURN_URL=turn:203.0.113.10:3478?transport=udp
TURN_USER=replace-me
TURN_PASSWORD=replace-me
TURN_PUBLIC_IP=203.0.113.10
TURN_RELAY_IP=10.0.2.128
TURN_REALM=ip-camera-webrtc-mobile
TURN_SERVER_NAME=multitek-turn
TURN_PORT=3478
TURN_MIN_PORT=48160
TURN_MAX_PORT=48200

# Signaling server exposed by the developer computer on the same Wi-Fi
SIGNALING_HOST=192.168.1.10
SIGNALING_PORT=3000
SIGNALING_AUTH_TOKEN=
GATEWAY_PUBLIC_BASE_URL=

# Optional server-side camera metadata
CAMERA_NAME=ofis_kamera
CAMERA_LABEL=Ofis Kamera
CAMERA_LOCATION=Multitek test alani
