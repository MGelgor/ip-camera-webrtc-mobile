# Signed Android release configuration. Copy to .env.release and keep it local.
EXPO_PUBLIC_SIGNALING_URL=wss://signaling.example.com/ws
EXPO_PUBLIC_NATIVE_WEBRTC_ENABLED=false

ANDROID_RELEASE_KEYSTORE_PATH=/absolute/path/to/release-upload.jks
ANDROID_RELEASE_STORE_PASSWORD=replace-me
ANDROID_RELEASE_KEY_ALIAS=replace-me
ANDROID_RELEASE_KEY_PASSWORD=replace-me
